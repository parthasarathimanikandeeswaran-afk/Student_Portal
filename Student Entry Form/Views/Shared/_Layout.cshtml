<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Portal</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>
<body>



    @if (Context.Session.GetString("Role") == "Admin")
    {
        
    <nav class="navbar navbar-expand-lg custom-navbar">
        <div class="container-fluid">

            <a class="navbar-brand text-white fw-bold" asp-controller="Student" asp-action="Home">
                🎓 Student Portal
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">

                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Student" asp-action="Home">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Student" asp-action="StudentEntry">Student Entry</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Student" asp-action="ResultForm">Search Result</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Student" asp-action="StudentsDetails">Student List</a>
                    </li>


                        <li class="nav-item">
                            <a class="nav-link text-white"  asp-controller="Student" asp-action="Logout">
                                <button class="logout-btn " style="background-color:orangered">Logout</button>
                            </a>
                        </li>


                </ul>
            </div>
        </div>
    </nav>

    }


            <main class="main-content">
                @RenderBody()
            </main>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>