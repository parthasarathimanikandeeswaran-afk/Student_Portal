        const districtSel = document.getElementById("district");
        const talukSel = document.getElementById("taluk");
        const villageSel = document.getElementById("village");
        const pincodeInput = document.getElementById("pincode");

      
        const selectedDistrict = "@Model.Student.District";
        const selectedTaluk = "@Model.Student.Taluk";
        const selectedVillage = "@Model.Student.Village";

       
        window.onload = () => {
            districtSel.innerHTML = `<option value="">-- Select District --</option>`;
            Object.keys(locationData).forEach(d => {
                const opt = new Option(d, d);
                if (d === selectedDistrict) opt.selected = true;
                districtSel.add(opt);
            });

            if (selectedDistrict) loadTaluks(selectedDistrict);
        };

        function loadTaluks(district) {
            talukSel.innerHTML = `<option value="">-- Select Taluk --</option>`;
            villageSel.innerHTML = `<option value="">-- Select Village --</option>`;
            pincodeInput.value = "";

            Object.keys(locationData[district]).forEach(t => {
                const opt = new Option(t, t);
                if (t === selectedTaluk) opt.selected = true;
                talukSel.add(opt);
            });

            if (selectedTaluk) loadVillages(district, selectedTaluk);
        }

        function loadVillages(district, taluk) {
            villageSel.innerHTML = `<option value="">-- Select Village --</option>`;
            const villages = locationData[district][taluk];

            Object.keys(villages).forEach(v => {
                const opt = new Option(v, v);
                if (v === selectedVillage) opt.selected = true;
                villageSel.add(opt);
            });

            if (selectedVillage) {
                pincodeInput.value = villages[selectedVillage];
            }
        }

        districtSel.addEventListener("change", () => {
            loadTaluks(districtSel.value);
        });

        talukSel.addEventListener("change", () => {
            loadVillages(districtSel.value, talukSel.value);
        });

        villageSel.addEventListener("change", () => {
            const pin =
                locationData[districtSel.value][talukSel.value][villageSel.value];
            pincodeInput.value = pin || "";
        });
    




        document.getElementById("editStudentForm").addEventListener("submit", function (e) {

            let error = document.getElementById("clientError");
            error.innerText = "";

            let fullName = document.getElementById("FullName").value.trim();
            let mobile = document.getElementById("Mobile").value.trim();
            let dob = document.getElementById("DateOfBirth").value;

            if (fullName === "") {
                error.innerText = "❌ Full Name is required";
                e.preventDefault();
                return;
            }

            if (!/^[6-9]\d{9}$/.test(mobile)) {
                error.innerText = "❌ Enter valid 10 digit mobile number";
                e.preventDefault();
                return;
            }

            if (dob === "") {
                error.innerText = "❌ Date of Birth is required";
                e.preventDefault();
                return;
            }

            let markInputs = document.querySelectorAll("input[type='number']");

            for (let i = 0; i < markInputs.length; i++) {
                let val = markInputs[i].value;

                if (val === "") {
                    error.innerText = "❌ All marks are required";
                    e.preventDefault();
                    return;
                }

                let mark = parseInt(val);

                if (mark < 0 || mark > 100) {
                    error.innerText = "❌ Marks must be between 0 and 100";
                    e.preventDefault();
                    return;
                }
            }

        });
    </script>
