@model Student_Entry_Form.Models.StudentEditViewModel

<link rel="stylesheet" href="~/css/StudentEdit.css" />

<div class="edit-container">
    <h1>Update Student</h1>
    <span>Ack No: @Model.Student.AckNo</span>

    <form asp-action="EditStudent" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Student.StudentId" />
        <input type="hidden" asp-for="Student.AckNo" />

        <div class="search-form">

            <div class="form-group">
                <label for="FullName">Full Name</label>
                <input asp-for="Student.FullName" id="FullName" placeholder="Enter full name" />
            </div>

            <div class="form-group">
                <label for="Email">Email</label>
                <input asp-for="Student.Email" id="Email" placeholder="Enter email" />
            </div>

            <div class="form-group">
                <label for="Mobile">Mobile</label>
                <input asp-for="Student.Mobile" id="Mobile" placeholder="Enter mobile number" />
            </div>

            <div class="form-group">
                <label for="DateOfBirth">Date of Birth</label>
                <input asp-for="Student.DateOfBirth" type="date" id="DateOfBirth" />
            </div>

            <div class="form-group">
                <label for="AddressLine1">Address</label>
                <input asp-for="Student.AddressLine1" id="AddressLine1" placeholder="Enter address" />
            </div>

            <div class="form-group">
                <label>District</label>
                <select id="district" name="Student.District" required></select>
            </div>

            <div class="form-group">
                <label>Taluk</label>
                <select id="taluk" name="Student.Taluk" required></select>
            </div>

            <div class="form-group">
                <label>Village</label>
                <select id="village" name="Student.Village" required></select>
            </div>

            <div class="form-group">
                <label>Pincode</label>
                <input asp-for="Student.Pincode" id="pincode" readonly />
            </div>


            <h3>Marks</h3>
            <table class="marks-table">
                <tr>
                    <th>Subject</th>
                    <th>Marks</th>
                </tr>
                @for (int i = 0; i < Model.Marks.Count; i++)
                {
                    <tr>
                        <td>
                            @Model.Marks[i].SubjectName
                            <input type="hidden" asp-for="Marks[i].SubjectId" />
                            <input type="hidden" asp-for="Marks[i].SubjectName" />
                        </td>
                        <td>
                            <input asp-for="Marks[i].Marks" type="number" min="0" max="100" />
                        </td>
                    </tr>
                }
            </table>

            <button type="submit" class="btn-update">Update</button>
            <a asp-action="StudentsDetails" class="btn-cancel">Cancel</a>
        </div>
    </form>
</div>









