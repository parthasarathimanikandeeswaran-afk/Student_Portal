    const district = document.getElementById("district");
    const taluk = document.getElementById("taluk");
    const village = document.getElementById("village");
    const pincode = document.getElementById("pincode");



    Object.keys(locationData).forEach(d =>
        district.add(new Option(d, d))
    );

    

    district.addEventListener("change", () => {
        taluk.innerHTML = `<option value="">-- Select Taluk --</option>`;
        village.innerHTML = `<option value="">-- Select Village --</option>`;
        pincode.value = "";

        taluk.disabled = true;
        village.disabled = true;

        if (!district.value) return;

        Object.keys(locationData[district.value]).forEach(t =>
            taluk.add(new Option(t, t))
        );

        taluk.disabled = false;
    });


    taluk.addEventListener("change", () => {
        village.innerHTML = `<option value="">-- Select Village --</option>`;
        pincode.value = "";
        village.disabled = true;

        if (!taluk.value) return;

        Object.keys(locationData[district.value][taluk.value])
            .forEach(v => village.add(new Option(v, v)));

        village.disabled = false;
    });

 
    village.addEventListener("change", () => {
        if (!village.value) {
            pincode.value = "";
            return;
        }

        pincode.value =
            locationData[district.value][taluk.value][village.value];
    });

  
    document.querySelectorAll("input[type='number']").forEach(i => {
        i.addEventListener("keyup", function () {
            const v = parseInt(this.value);
            const s = this.closest("tr").querySelector(".status");

            if (this.value === "") { s.textContent = ""; return; }

            if (v < 0 || v > 100 || isNaN(v)) {
                s.textContent = "Invalid"; s.style.color = "red"; return;
            }

            if (v < 35) s.textContent = "Fail";
            else if (v <= 50) s.textContent = "Pass";
            else if (v <= 80) s.textContent = "Good";
            else s.textContent = "Excellent";
        });
    });
