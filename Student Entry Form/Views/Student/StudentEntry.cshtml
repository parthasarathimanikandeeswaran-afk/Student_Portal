@model Student_Entry_Form.Models.StudentEntryModel
@{
    ViewData["Title"] = "Student Entry";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Student-Entry.css" />
}

<div class="student-entry-container">

    <div class="nav-bar">
        <h1>Student Information Entry</h1>
    </div>

    <h1>Enter Student Details</h1>

    <form asp-action="StudentEntry" asp-controller="Student" method="post">

        <div class="form-container">
            <div class="form-heading">
                <h2>Personal Details</h2>
            </div>

            <div class="form-input-container">

              
                <div class="form-input-box1">
                    <label>Name</label>
                    <input asp-for="Name" required />

                    <label>Email</label>
                    <input asp-for="Email" type="email" required />

                    <label>Phone Number</label>
                    <input asp-for="Mobile" required />

                    <label>Date of Birth</label>
                    <input asp-for="DateOfBirth" type="date" required />
                </div>

              
                <div class="form-input-box2">
                    <label>Address Line 1</label>
                    <input asp-for="AddressLine1" required />

                    <label>Address Line 2</label>
                    <input asp-for="AddressLine2" placeholder="Optional" />

                    <label>District</label>
                    <select id="district" asp-for="District" required>
                        <option value="">-- Select District --</option>
                    </select>

                    <label>Taluk</label>
                    <select id="taluk" asp-for="Taluk" disabled required>
                        <option value="">-- Select Taluk --</option>
                    </select>

                    <label>Village</label>
                    <select id="village" asp-for="Village" disabled required>
                        <option value="">-- Select Village --</option>
                    </select>

                    <label>Pincode</label>
                    <input asp-for="Pincode" id="pincode" readonly />
                </div>

            </div>
        </div>

        <div class="marks-details">
            <h2>Marks Details</h2>

            <table>
                <tr>
                    <th>Subject</th>
                    <th>Marks</th>
                    <th>Status</th>
                </tr>

                <tr>
                    <td>Tamil</td>
                    <td><input asp-for="Tamil" type="number" min="0" max="100" /></td>
                    <td class="status"></td>
                </tr>
                <tr>
                    <td>English</td>
                    <td><input asp-for="English" type="number" min="0" max="100" /></td>
                    <td class="status"></td>
                </tr>
                <tr>
                    <td>Mathematics</td>
                    <td><input asp-for="Maths" type="number" min="0" max="100" /></td>
                    <td class="status"></td>
                </tr>
                <tr>
                    <td>Science</td>
                    <td><input asp-for="Science" type="number" min="0" max="100" /></td>
                    <td class="status"></td>
                </tr>
                <tr>
                    <td>Social Science</td>
                    <td><input asp-for="Social" type="number" min="0" max="100" /></td>
                    <td class="status"></td>
                </tr>
            </table>

            <button type="submit">Submit</button>
        </div>
    </form>
</div>

